{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [],
  "provider": {
    "OmniRoute": {
      "name": "OmniRoute (local)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "qw/qwen3-coder-plus": {
          "name": "qw/qwen3-coder-plus"
        },
        "qw/qwen3-coder-flash": {
          "name": "qw/qwen3-coder-flash"
        },
        "qw/coder-model": {
            "name": "qw/coder-model"
        },
        "kr/claude-opus-4.7": {
          "name": "kr/claude-opus-4.7"
        },
        "kr/claude-opus-4.6": {
          "name": "kr/claude-opus-4.6"
        },
        "kr/claude-sonnet-4.6": {
            "name": "kr/claude-sonnet-4.6"
        },
        "kr/claude-sonnet-4.5": {
            "name": "kr/claude-sonnet-4.5"
        },
        "kr/claude-haiku-4.5": {
            "name": "kr/claude-haiku-4.5"
        }
      },
      "options": {
        "baseURL": "http://host.docker.internal:20128/v1"
      }
    }
  }
}

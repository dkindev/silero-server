# Environment variables template
# Copy this file to .env and update values as needed

# Infrastructure
TTS_ENV_TYPE=development
TTS_URI=tcp://127.0.0.1:10200
TTS_ZEROCONF=silero-tts
TTS_STREAMING=true

# PyTorch computing engine
TTS_TORCH__DEVICE=cpu
TTS_TORCH__NUM_THREADS=4
TTS_TORCH__NUM_INTEROP_THREADS=1
TTS_TORCH__FLUSH_DENORMAL=true

# TTS Configuration
TTS_SAMPLE_RATE=48000
TTS_MAX_MODELS=2
TTS_MAX_CONCURRENT_PER_MODEL=2
TTS_MAX_CHUNK_CHARS=140
TTS_DATA_YML_PATH=data/data.yml
TTS_MODELS_DIR=models/silero
TTS_MODELS_YML_URL=https://raw.githubusercontent.com/snakers4/silero-models/refs/heads/master/models.yml
TTS_MODELS_YML_HASH=

# Text normalization
TTS_NORMALIZATION__TIMEOUT=5
TTS_NORMALIZATION__MAX_CONCURRENT_CHUNKS_PER_REQUEST=2
TTS_NORMALIZATION__TEXT_ENABLED=true
TTS_NORMALIZATION__TEXT_TYPE=simple
TTS_NORMALIZATION__SSML_ENABLED=false
TTS_NORMALIZATION__SSML_TYPE=simple

# OpenAI-compatible API (for LLM-based normalization)
TTS_OPENAI__BASE_URL=
TTS_OPENAI__API_KEY=

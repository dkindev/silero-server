# Environment variables template
# Copy this file to .env and update values as needed

# TTS Configuration
TTS_TORCH_DEVICE=cpu
TTS_TORCH_NUM_THREADS=4
TTS_TORCH_NUM_INTEROP_THREADS=1
TTS_TORCH_FLUSH_DENORMAL=true
TTS_SAMPLE_RATE=48000
TTS_MAX_TEXT_LENGTH=1000
TTS_ALLOWED_ORIGINS=*
TTS_CONFIG_PATH=silero-to-mary-config.yml
TTS_MAX_MODELS=2
TTS_MAX_CONCURRENT_PER_MODEL=2
TTS_MAX_CHUNK_CHARS=140
TTS_MODELS_DIR=.models/silero
TTS_ENV_TYPE=development
TTS_MODELS_YML_URL=https://raw.githubusercontent.com/snakers4/silero-models/88959d6c73168cab4f1487f63754c7c7c96b78a8/models.yml
TTS_MODELS_YML_HASH=c981f239ed79b3924f952eb3a4dee3a03221d9867330c2b4054c767df77a86d8
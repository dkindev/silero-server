# Environment variables template
# Copy this file to .env and update values as needed

# TTS Configuration
TTS_DEVICE=cpu
TTS_SAMPLE_RATE=48000
TTS_MAX_TEXT_LENGTH=1000
TTS_ALLOWED_ORIGINS=*
TTS_SHUTDOWN_TIMEOUT=10
TTS_CONFIG_PATH=silero-to-mary-config.yml
TTS_MAX_MODELS=2
TTS_MAX_CONCURRENT_PER_MODEL=2